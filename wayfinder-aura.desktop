[Desktop Entry]
Type=Application
Name=Wayfinder Aura
GenericName=Voice Dictation
Comment=Local voice dictation for Linux (Wayland)
# @WAYFINDER_ROOT@ is rewritten to the install path by build.sh / install scripts.
Exec=@WAYFINDER_ROOT@/launch-wayfinder-aura.sh
Icon=@WAYFINDER_ROOT@/assets/icon.png
Terminal=false
Categories=Utility;Accessibility;
Keywords=voice;dictation;speech;whisper;transcription;speech-to-text;
StartupNotify=true
StartupWMClass=Wayfinder-aura
Actions=toggle-recording;cycle-style;

[Desktop Action toggle-recording]
Name=Toggle Recording
Exec=python3 @WAYFINDER_ROOT@/trigger_record.py
Icon=@WAYFINDER_ROOT@/assets/icon.png

[Desktop Action cycle-style]
Name=Cycle Output Style
Exec=python3 @WAYFINDER_ROOT@/trigger_style.py
Icon=@WAYFINDER_ROOT@/assets/icon.png
